# Copiá este archivo como .env y completá los valores reales.
# NUNCA subas .env al repositorio.

# Clave secreta para sesiones Flask. Generá una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esta_clave_por_una_cadena_aleatoria_larga

# Entorno (development | production)
FLASK_ENV=development

# Base de datos (dejar vacío para usar SQLite local)
# DATABASE_URL=postgresql://user:pass@host/dbname

# Datos de contacto que aparecen en el sitio público
CONTACTO_TELEFONO=+54 9 11 XXXX-XXXX
CONTACTO_WA=549XXXXXXXXXX
CONTACTO_EMAIL=tu@email.com

# Notificaciones de email al recibir consultas (dejar vacío para desactivar)
# Para Gmail: activá "Contraseñas de aplicación" en tu cuenta Google
MAIL_SMTP=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx
MAIL_TO=donde_recibir@gmail.com
